<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Your Brobier login code</title>
    <style>
      body {
        margin: 0;
        padding: 24px;
        background: #f4f1ea;
        color: #2d2418;
        font-family: Arial, sans-serif;
      }

      .card {
        max-width: 560px;
        margin: 0 auto;
        padding: 32px;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(61, 43, 20, 0.08);
      }

      .eyebrow {
        margin: 0 0 12px;
        color: #8a6d3b;
        font-size: 14px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .title {
        margin: 0 0 16px;
        font-size: 28px;
        line-height: 1.2;
      }

      .copy {
        margin: 0 0 24px;
        font-size: 16px;
        line-height: 1.6;
      }

      .code-block {
        margin: 0 0 24px;
        padding: 18px 20px;
        background: #f9f5ee;
        border: 1px solid #eadfce;
        border-radius: 12px;
        text-align: center;
      }

      .code {
        color: #5c4320;
        font-size: 32px;
        font-weight: 700;
        letter-spacing: 0.24em;
      }

      .footer {
        margin: 0;
        color: #6a5a45;
        font-size: 14px;
        line-height: 1.6;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <p class="eyebrow">Brobier login</p>
      <h1 class="title">Your login code</h1>
      <p class="copy">
        Use the code below to sign in. It stays valid for {{ expires_in_minutes }} minutes.
      </p>
      <div class="code-block">
        <span class="code">{{ code }}</span>
      </div>
      <p class="footer">
        If you did not request this code, you can safely ignore this email.
      </p>
    </div>
  </body>
</html>
